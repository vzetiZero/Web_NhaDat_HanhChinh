# =====================================================================
# .env.example - Template config cho backend
# Copy file này thành .env và điền giá trị thật
# =====================================================================
#
# 🔄 Khi switch sang Supabase project KHÁC, chỉ cần đổi 3 biến:
#    1. DATABASE_URL    (gồm project-ref + region + password mới)
#    2. SUPABASE_URL    (https://<new-ref>.supabase.co)
#    3. SUPABASE_SERVICE_ROLE_KEY  (JWT mới)
# Các biến khác giữ nguyên.
# =====================================================================

# ==== App ====
NODE_ENV=development
PORT=3000

# ==== Database (PostgreSQL từ Supabase) ====
# Lấy từ: Dashboard → Settings → Database → Connection string.
# Lưu ý: nếu password chứa ký tự đặc biệt như "@", "!", "#" → URL-encode:
#   @ → %40    ! → %21    # → %23    $ → %24    & → %26    + → %2B
# Cluster mới (project sinh từ 2025) dùng "aws-1-", cũ dùng "aws-0-".
#
# DATABASE_URL = runtime của app → TRANSACTION POOLER (port 6543) + ?pgbouncer=true.
#   Bắt buộc dùng để tránh lỗi "max clients reached in session mode" (session cap 15).
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# DIRECT_URL = chỉ cho `prisma migrate`/`db push` (DDL cần session thật, không qua pgBouncer).
#   Trỏ Session Pooler (port 5432).
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres

# ==== Supabase ====
# Lấy từ: Dashboard → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY_NOT_ANON]

# Tên bucket - tự đặt tùy bạn. Backend sẽ auto-create lúc boot (cần service_role quyền create).
# Có thể tạo thủ công trong Dashboard → Storage → New bucket (đặt private).
SUPABASE_STORAGE_BUCKET=contract-files
SUPABASE_TEMPLATE_BUCKET=contract-templates

# Signed URL lifetime (giây). 600 = 10 phút.
SUPABASE_SIGNED_URL_TTL=600

# ==== Auth ====
# Sinh ngẫu nhiên:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Hoặc PowerShell:  -join ((1..32) | %{ '{0:x2}' -f (Get-Random -Min 0 -Max 256) })
JWT_SECRET=[64-char-hex-random]
JWT_EXPIRES_IN=7d

# AES-256 cho mã hóa CCCD trong DB. 32+ ký tự.
ENCRYPTION_KEY=[64-char-hex-random]

# ==== Admin bootstrap - chỉ dùng cho `npm run db:seed` lần đầu ====
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe@123

# ==== CORS - origins được phép gọi API ====
# Production: chỉ ghi domain frontend thật. Vd: https://app.yourcompany.vn
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ==== Rate limit ====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ==== Logging ====
LOG_LEVEL=info

# ==== Optional - Telegram notification cho admin ====
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ==== Optional - Cloudflare Turnstile captcha ====
# TURNSTILE_SECRET=
# TURNSTILE_SITE_KEY=

# ==== Optional - API dữ liệu cơ quan chính thức/DVCQG ====
# Nếu có endpoint và token tích hợp chính thức, backend sẽ gọi nguồn này trước.
# Nếu không cấu hình hoặc không có kết quả, hệ thống tự fallback về DB seed/user suggestions.
# DVCQG_AGENCY_API_URL=https://...
# DVCQG_API_KEY=
